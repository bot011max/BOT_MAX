func (h *APIHandler) CreatePrescription(c *gin.Context) {
    doctorID := c.GetString("user_id")
    
    var presc Prescription
    if err := c.ShouldBindJSON(&presc); err != nil {
        c.JSON(http.StatusBadRequest, Response{Error: err.Error()})
        return
    }
    
    presc.DoctorID = uuid.MustParse(doctorID)
    presc.IssuedAt = time.Now()
    presc.ValidUntil = time.Now().AddDate(0, 2, 0) // 2 месяца
    
    if err := h.db.DB.Create(&presc).Error; err != nil {
        c.JSON(http.StatusInternalServerError, Response{Error: err.Error()})
        return
    }
    
    // Проверяем безопасность
