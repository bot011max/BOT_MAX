func (s *TemplateService) GenerateDocument(templateID uuid.UUID, patientID uuid.UUID, data map[string]interface{}) (*GeneratedDocument, error) {
    var template DocumentTemplate
    if err := s.db.DB.First(&template, "id = ?", templateID).Error; err != nil {
        return nil, err
    }
    
    var patient Patient
    if err := s.db.DB.Preload("User").First(&patient, "id = ?", patientID).Error; err != nil {
        return nil, err
    }
    
    // Подготавливаем данные
    templateData := make(map[string]interface{})
    
    // Данные пациента
    templateData["patientLastName"] = patient.User.LastName
    templateData["patientFirstName"] = patient.User.FirstName
    templateData["patientMiddleName"] = patient.User.MiddleName
    templateData["patientFullName"] = fmt.Sprintf("%s %s %s", 
        patient.User.LastName, patient.User.FirstName, patient.User.MiddleName)
    
    if patient.BirthDate != nil {
        templateData["patientBirthDate"] = patient.BirthDate.Format("02.01.2006")
        age := time.Now().Year() - patient.BirthDate.Year()
        templateData["patientAge"] = age
    }
    
    templateData["patientSnils"] = patient.Snils
    templateData["patientPolis"] = patient.Polis
    
    // Системные данные
    templateData["currentDate"] = time.Now().Format("02.01.2006")
    templateData["currentDateTime"] = time.Now().Format("02.01.2006 15:04")
    
    // Пользовательские данные
    for k, v := range data {
        templateData[k] = v
    }
    
    // Парсим шаблон
    tmpl, err := template.New("document").Parse(template.TemplateHTML)
    if err != nil {
        return nil, err
    }
    
    var buf bytes.Buffer
    if err := tmpl.Execute(&buf, templateData); err != nil {
        return nil, err
    }
    
    // Сохраняем сгенерированный документ
    doc := &GeneratedDocument{
        TemplateID: templateID,
        PatientID:  patientID,
        FilledData: templateData,
        FinalHTML:  buf.String(),
        Status:     "draft",
    }
    
    if err := s.db.DB.Create(doc).Error; err != nil {
        return nil, err
    }
    
    // Увеличиваем счетчик использования
    s.db.DB.Model(&template).Update("usage_count", template.UsageCount+1)
    s.db.DB.Model(&template).Update("last_used_at", time.Now())
    
    return doc, nil
}

