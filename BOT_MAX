func (s *PromptService) GetPromptForSpecialty(specialty string, clinicID *uuid.UUID) (*MedicalPrompt, error) {
    var prompt MedicalPrompt
    
    // Сначала ищем кастомный для клиники
    if clinicID != nil {
        err := s.db.DB.Where("specialty = ? AND clinic_id = ?", specialty, clinicID).
            Order("version DESC").First(&prompt).Error
        if err == nil {
            return &prompt, nil
        }
    }
    
    // Иначе публичный
    err := s.db.DB.Where("specialty = ? AND is_public = ?", specialty, true).
        Order("version DESC").First(&prompt).Error
    if err != nil {
        return nil, err
    }
    
    return &prompt, nil
}

func (s *PromptService) ApplyPrompt(promptID uuid.UUID, patientID uuid.UUID, additionalData map[string]interface{}) (map[string]interface{}, error) {
    var prompt MedicalPrompt
    if err := s.db.DB.First(&prompt, "id = ?", promptID).Error; err != nil {
        return nil, err
    }
    
    // Получаем последние записи пациента
    var records []MedicalRecord
    if err := s.db.DB.Where("patient_id = ?", patientID).
        Order("visit_date desc").Limit(10).Find(&records).Error; err != nil {
        return nil, err
    }
    
    // Формируем текст для анализа
    var textBuilder strings.Builder
    for _, r := range records {
        textBuilder.WriteString(fmt.Sprintf("Дата: %s\n", r.VisitDate.Format("02.01.2006")))
        
        var complaints map[string]interface{}
        json.Unmarshal(r.Complaints, &complaints)
        if text, ok := complaints["text"]; ok {
            textBuilder.WriteString(fmt.Sprintf("Жалобы: %s\n", text))
        }
        
        var diagnosis map[string]interface{}
        json.Unmarshal(r.Diagnosis, &diagnosis)
        if main, ok := diagnosis["main_diagnosis"]; ok {
            textBuilder.WriteString(fmt.Sprintf("Диагноз: %v\n", main))
        }
        
        textBuilder.WriteString("\n")
    }
    
    // Применяем каждый уровень
    result := make(map[string]interface{})
    
    // Уровень 0: Синопсис
    if prompt.Level0System != "" {
        resp, err := s.llmClient.Analyze(prompt.Level0System, textBuilder.String())
        if err == nil {
            result["synopsis"] = resp
        }
    }
    
    // Уровень 1: Диагностические якоря
    if len(prompt.Level1Prompts) > 0 {
        var level1 map[string]interface{}
        json.Unmarshal(prompt.Level1Prompts, &level1)
        if system, ok := level1["system"].(string); ok {
            resp, err := s.llmClient.Analyze(system, textBuilder.String())
            if err == nil {
                result["diagnostic_anchors"] = resp
            }
        }
    }
    
    // Увеличиваем счетчик
    s.db.DB.Model(&prompt).Update("usage_count", prompt.UsageCount+1)
    
    return result, nil
}

