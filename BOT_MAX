func (c *LLMClient) Analyze(prompt string, text string) (map[string]interface{}, error) {
    request := map[string]interface{}{
        "prompt": prompt,
        "text":   text,
    }
    
    data, _ := json.Marshal(request)
    
    resp, err := c.client.Post(c.baseURL+"/analyze", "application/json", bytes.NewReader(data))
    if err != nil {
        return nil, err
    }
    defer resp.Body.Close()
    
    var result map[string]interface{}
    if err := json.NewDecoder(resp.Body).Decode(&result); err != nil {
        return nil, err
    }
    
    return result, nil
}

