    // Создаем напоминания для пациента
    var medications []map[string]interface{}
    json.Unmarshal(presc.Medications, &medications)
    
    for _, med := range medications {
        task := Task{
            Type: "reminder.create",
            Payload: map[string]interface{}{
                "patient_id": presc.PatientID,
                "medication": med,
                "prescription_id": presc.ID,
            },
            ScheduledFor: timePtr(time.Now().Add(1 * time.Hour)),
            Status:       "pending",
        }
        h.db.DB.Create(&task)
    }
    
    c.JSON(http.StatusCreated, Response{
        Success: true,
        Data: gin.H{
            "prescription": presc,
            "alerts":      alerts,
        },
    })
