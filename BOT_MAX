func (a *MedodsAdapter) GetPatient(ctx context.Context, externalID string) (*Patient, error) {
    url := fmt.Sprintf("%s/api/v1/patients/%s", a.baseURL, externalID)
    
    req, err := http.NewRequestWithContext(ctx, "GET", url, nil)
    if err != nil {
        return nil, err
    }
    
    req.Header.Set("Authorization", a.generateAuthHeader())
    
    resp, err := a.httpClient.Do(req)
    if err != nil {
        return nil, err
    }
    defer resp.Body.Close()
    
    if resp.StatusCode == http.StatusNotFound {
        return nil, nil
    }
    
    if resp.StatusCode != http.StatusOK {
        return nil, fmt.Errorf("MEDODS API error: %d", resp.StatusCode)
    }
    
    var medodsPatient struct {
        ID        string `json:"id"`
        LastName  string `json:"last_name"`
        FirstName string `json:"first_name"`
        MiddleName string `json:"middle_name"`
        BirthDate string `json:"birth_date"`
        Gender    string `json:"gender"`
        Phone     string `json:"phone"`
        Email     string `json:"email"`
        IIN       string `json:"iin"`
    }
    
    if err := json.NewDecoder(resp.Body).Decode(&medodsPatient); err != nil {
        return nil, err
    }
    
    birthDate, _ := time.Parse("2006-01-02", medodsPatient.BirthDate)
    
    return &Patient{
        BaseModel: BaseModel{ID: uuid.New()},
        BirthDate: &birthDate,
        Gender:    medodsPatient.Gender,
        Snils:     medodsPatient.IIN,
    }, nil
}

func (a *MedodsAdapter) generateAuthHeader() string {
    timestamp := strconv.FormatInt(time.Now().Unix(), 10)
    message := a.identity + ":" + timestamp
    hash := sha256.Sum256([]byte(message + ":" + a.secretKey))
    signature := base64.StdEncoding.EncodeToString(hash[:])
    
    return fmt.Sprintf("JWA %s:%s:%s", a.identity, timestamp, signature)
}

