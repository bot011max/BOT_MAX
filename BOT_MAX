type Server struct {
    config     *Config
    db         *Database
    router     *gin.Engine
    auth       *AuthService
    middleware *Middleware
    safety     *SafetyService
    templates  *TemplateService
    prompts    *PromptService
    payments   *PaymentService
    misFactory *AdapterFactory
    misManager *MISConnectionManager
    worker     *Worker
    httpServer *http.Server
}

func NewServer(cfg *Config) (*Server, error) {
    // База данных
    db, err := NewDatabase(cfg)
    if err != nil {
        return nil, err
    }
    
    // Миграции
    if err := db.AutoMigrate(); err != nil {
        return nil, err
    }
    
    // Инициализация тарифов
    InitSubscriptionTiers(db)
    
    // Сервисы
    auth := NewAuthService(cfg.JWTSecret, cfg.JWTExpiryHours)
    middleware := NewMiddleware(auth, db)
    safety := NewSafetyService(db)
    templates := NewTemplateService(db)
    prompts := NewPromptService(db, cfg.LLMServiceURL)
    payments := NewPaymentService(cfg.YooKassaShopID, cfg.YooKassaSecret, db)
    misFactory := NewAdapterFactory()
    misManager := NewMISConnectionManager(db, misFactory, db.Encryption)
    
    // Воркер
    worker := NewWorker(db)
    
    // Роутер
    router := gin.New()
    router.Use(gin.Recovery())
    router.Use(cors.Default())
    router.Use(middleware.AuditLog())
    
    s := &Server{
        config:     cfg,
        db:         db,
        router:     router,
        auth:       auth,
        middleware: middleware,
        safety:     safety,
        templates:  templates,
        prompts:    prompts,
        payments:   payments,
        misFactory: misFactory,
        misManager: misManager,
        worker:     worker,
    }
    
    s.setupRoutes()
    
    return s, nil
}

func (s *Server) setupRoutes() {
    api := s.router.Group("/api")
    
    // Публичные
    api.POST("/register", s.Register)
    api.POST("/login", s.Login)
    api.GET("/health", func(c *gin.Context) {
        c.JSON(http.StatusOK, gin.H{"status": "ok", "version": AppVersion})
    })
    
    // Защищенные
    authorized := api.Group("/")
    authorized.Use(s.middleware.AuthRequired())
    {
        // Подписки (доступны всем)
        authorized.GET("/subscription/plans", s.GetPlans)
        authorized.GET("/subscription/my", s.GetMySubscription)
        authorized.POST("/subscription/create", s.CreateSubscription)
        
        // Пациенты (для врачей и клиник)
        patients := authorized.Group("/patients")
        patients.Use(s.middleware.RoleRequired(RoleDoctor, RoleClinic))
        patients.Use(s.middleware.SubscriptionRequired())
        patients.Use(s.middleware.CheckPatientLimit())
        {
            patients.GET("/", s.GetMyPatients)
            patients.GET("/:patient_id", s.middleware.PatientAccess(), s.GetPatientEMR)
            patients.POST("/:patient_id/record", s.middleware.PatientAccess(), s.CreateMedicalRecord)
            patients.GET("/:patient_id/safety", s.middleware.PatientAccess(), s.CheckPatientSafety)
            patients.GET("/:patient_id/alerts", s.middleware.PatientAccess(), s.GetPatientAlerts)
        }
        
        // Рецепты
        prescriptions := authorized.Group("/prescriptions")
        prescriptions.Use(s.middleware.RoleRequired(RoleDoctor, RoleClinic))
        prescriptions.Use(s.middleware.SubscriptionRequired())
        {
            prescriptions.POST("/", s.CreatePrescription)
        }
        
        // Шаблоны
        templates := authorized.Group("/templates")
        templates.Use(s.middleware.RoleRequired(RoleDoctor, RoleClinic))
        {
            templates.GET("/", s.GetTemplates)
            templates.POST("/", s.CreateTemplate)
            templates.POST("/generate", s.GenerateDocument)
        }
        
        // Промты
        prompts := authorized.Group("/prompts")
        prompts.Use(s.middleware.RoleRequired(RoleDoctor, RoleClinic))
        {
            prompts.GET("/", s.GetPrompts)
            prompts.POST("/", s.CreatePrompt)
            prompts.POST("/:id/apply/:patient_id", s.ApplyPrompt)
        }
        
        // Голосовой ввод (для всех)
        voice := authorized.Group("/voice")
        {
            voice.POST("/upload/:patient_id", s.UploadVoice)
        }
        
        // Анализы (для всех)
        lab := authorized.Group("/lab")
        {
            lab.POST("/upload/:patient_id", s.UploadLabResult)
        }
        
        // Интеграция с МИС (только для клиник)
        mis := authorized.Group("/mis")
        mis.Use(s.middleware.RoleRequired(RoleClinic))
        {
            mis.POST("/connect", s.ConnectMIS)
            mis.POST("/sync", s.SyncWithMIS)
        }
        
        // Для пациентов (свои данные)
        me := authorized.Group("/me")
        me.Use(s.middleware.RoleRequired(RolePatient))
        {
            me.GET("/record", func(c *gin.Context) {
                patientID := c.GetString("user_id")
                c.Request.URL.Path = fmt.Sprintf("/api/patients/%s/record", patientID)
                s.router.HandleContext(c)
            })
            me.GET("/safety", func(c *gin.Context) {
                patientID := c.GetString("user_id")
                c.Request.URL.Path = fmt.Sprintf("/api/patients/%s/safety", patientID)
                s.router.HandleContext(c)
            })
        }
    }
    
    // WebSocket для уведомлений
    s.router.GET("/ws", s.handleWebSocket)
}

func (s *Server) handleWebSocket(c *gin.Context) {
    conn, err := wsUpgrader.Upgrade(c.Writer, c.Request, nil)
    if err != nil {
        return
    }
    defer conn.Close()
    
    userID := c.Query("user_id")
    if userID == "" {
        return
    }
    
    wsMutex.Lock()
    wsClients[userID] = conn
    wsMutex.Unlock()
    
    defer func() {
        wsMutex.Lock()
        delete(wsClients, userID)
        wsMutex.Unlock()
    }()
    
    for {
        var msg map[string]interface{}
        if err := conn.ReadJSON(&msg); err != nil {
            break
        }
        // Обработка входящих сообщений
    }
}

func (s *Server) Start() error {
    // Запуск воркера
    s.worker.Start()
    
    // HTTP сервер
    s.httpServer = &http.Server{
        Addr:         ":" + s.config.ServerPort,
        Handler:      s.router,
        ReadTimeout:  15 * time.Second,
        WriteTimeout: 15 * time.Second,
        IdleTimeout:  60 * time.Second,
    }
    
    s.router.GET("/", func(c *gin.Context) {
        c.JSON(http.StatusOK, gin.H{
            "app":     AppName,
            "version": AppVersion,
            "status":  "running",
        })
    })
    
    log.Printf("Server starting on port %s", s.config.ServerPort)
    return s.httpServer.ListenAndServe()
}

func (s *Server) Shutdown(ctx context.Context) error {
    s.worker.Stop()
    return s.httpServer.Shutdown(ctx)
}

