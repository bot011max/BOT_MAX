    if isYearly {
        amount = tier.PriceYearly
        description = fmt.Sprintf("Годовая подписка %s", tier.Name)
    }
    
    payment := map[string]interface{}{
        "amount": map[string]interface{}{
            "value":    amount,
            "currency": "RUB",
        },
        "capture": true,
        "confirmation": map[string]string{
            "type":      "redirect",
            "return_url": "https://yourbot.com/payment/success",
        },
        "description": description,
        "metadata": map[string]string{
            "user_id": userID.String(),
            "tier_id": tier.ID.String(),
            "type":    "subscription",
            "period":  map[bool]string{true: "yearly", false: "monthly"}[isYearly],
        },
    }
    
    data, _ := json.Marshal(payment)
    
    req, err := http.NewRequest("POST", "https://api.yookassa.ru/v3/payments", bytes.NewReader(data))
    if err != nil {
        return nil, err
    }
    
    req.SetBasicAuth(s.shopID, s.secretKey)
    req.Header.Set("Content-Type", "application/json")
    req.Header.Set("Idempotence-Key", uuid.New().String())
    
    resp, err := s.httpClient.Do(req)
    if err != nil {
        return nil, err
    }
    defer resp.Body.Close()
    
    var result PaymentResponse
    if err := json.NewDecoder(resp.Body).Decode(&result); err != nil {
        return nil, err
    }
    
    return &result, nil
}

func (s *PaymentService) HandleWebhook(payload []byte) error {
    var webhook struct {
        Event   string `json:"event"`
        Object  struct {
            ID       string `json:"id"`
            Status   string `json:"status"`
            Metadata struct {
                UserID   string `json:"user_id"`
                TierID   string `json:"tier_id"`
                Period   string `json:"period"`
            } `json:"metadata"`
        } `json:"object"`
    }
    
    if err := json.Unmarshal(payload, &webhook); err != nil {
        return err
    }
    
    if webhook.Event == "payment.succeeded" {
        userID := webhook.Object.Metadata.UserID
        tierID := webhook.Object.Metadata.TierID
        period := webhook.Object.Metadata.Period
        
        // Активируем подписку
        var tier SubscriptionTier
        if err := s.db.DB.First(&tier, "id = ?", tierID).Error; err != nil {
            return err
        }
        
        now := time.Now()
        endDate := now.AddDate(0, 1, 0) // на месяц
        if period == "yearly" {
            endDate = now.AddDate(1, 0, 0)
        }
        
        sub := UserSubscription{
            UserID:   uuid.MustParse(userID),
            TierID:   tier.ID,
            StartDate: now,
            EndDate:   &endDate,
            Status:    SubActive,
        }
        
        return s.db.DB.Create(&sub).Error
    }
    
    return nil
}

