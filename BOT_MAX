func (s *SafetyService) CheckPatientSafety(patientID uuid.UUID) ([]SafetyAlert, error) {
    var alerts []SafetyAlert
    
    // Получаем пациента
    var patient Patient
    if err := s.db.DB.First(&patient, "id = ?", patientID).Error; err != nil {
        return nil, err
    }
    
    // Получаем возраст
    age := 0
    if patient.BirthDate != nil {
        age = time.Now().Year() - patient.BirthDate.Year()
    }
    
    // Получаем все рецепты пациента
    var prescriptions []Prescription
    s.db.DB.Where("patient_id = ? AND valid_until > ?", patientID, time.Now()).
        Find(&prescriptions)
    
    // Собираем все препараты
    var allMedications []string
    for _, p := range prescriptions {
        var meds []map[string]interface{}
        json.Unmarshal(p.Medications, &meds)
        for _, m := range meds {
            if name, ok := m["name"].(string); ok {
                allMedications = append(allMedications, name)
            }
        }
    }
    
    // 1. Проверка по критериям Бирса (для пожилых)
    if age >= 65 {
        for _, med := range allMedications {
            if rule, exists := s.beersCriteria[strings.ToLower(med)]; exists {
                alerts = append(alerts, SafetyAlert{
                    PatientID:    patientID,
                    AlertType:    AlertBeers,
                    Severity:     "warning",
                    Medications:  []string{med},
                    Title:        "Потенциально нерекомендованный препарат для пожилых",
                    Description:  rule.Rationale,
                    Recommendation: rule.Recommendation,
                    Source:       "Beers Criteria 2025",
                })
            }
        }
    }
    
    // 2. Проверка почечной элиминации
    if patient.EGFR > 0 {
        for _, med := range allMedications {
            if adjust, exists := s.renalDosing[strings.ToLower(med)]; exists && adjust.NeedAdjustment {
                // Найти порог
                var threshold float64
                for egfr := range adjust.Thresholds {
                    if patient.EGFR < egfr {
                        threshold = egfr
                    }
                }
                if doseAdjust, ok := adjust.Thresholds[threshold]; ok {
                    alerts = append(alerts, SafetyAlert{
                        PatientID:    patientID,
                        AlertType:    AlertRenal,
                        Severity:     "critical",
                        Medications:  []string{med},
                        Title:        "Требуется коррекция дозы по функции почек",
                        Description:  fmt.Sprintf("СКФ: %.1f мл/мин. Требуется коррекция дозы", patient.EGFR),
                        Recommendation: doseAdjust.Notes,
                        Source:       "Клинические рекомендации по коррекции доз",
                    })
                }
            }
        }
    }
    
    // 3. Проверка полипрагмазии
    if len(allMedications) >= 5 {
        alerts = append(alerts, SafetyAlert{
            PatientID:    patientID,
            AlertType:    AlertPolypharmacy,
            Severity:     "warning",
            Medications:  allMedications,
            Title:        "Полипрагмазия",
            Description:  fmt.Sprintf("Пациент принимает %d препаратов", len(allMedications)),
            Recommendation: "Провести ревизию назначений, оценить необходимость каждого препарата",
            Source:       "Критерии STOPP/START",
        })
    }
    
    // 4. Проверка дублирования
    classCount := make(map[string]int)
    for _, med := range allMedications {
        // Упрощенно: определяем класс по окончанию названия
        class := "other"
        if strings.Contains(med, "прил") || strings.Contains(med, "сартан") {
            class = "гипотензивные"
        } else if strings.Contains(med, "профен") || strings.Contains(med, "коксиб") {
            class = "нпвс"
        } else if strings.Contains(med, "азепам") || strings.Contains(med, "золам") {
            class = "бензодиазепины"
        }
        classCount[class]++
    }
    
    for class, count := range classCount {
        if count > 1 && class != "other" {
            alerts = append(alerts, SafetyAlert{
                PatientID:    patientID,
                AlertType:    AlertInteraction,
                Severity:     "warning",
                Title:        "Дублирование терапии",
                Description:  fmt.Sprintf("Обнаружено %d препаратов класса '%s'", count, class),
                Recommendation: "Рассмотреть возможность отмены дублирующих препаратов",
                Source:       "Клинические рекомендации",
            })
        }
    }
    
    // Сохраняем алерты в БД
    for _, alert := range alerts {
        s.db.DB.Create(&alert)
    }
    
    return alerts, nil
}

