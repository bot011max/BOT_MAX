type Worker struct {
    db     *Database
    logger *log.Logger
    stop   chan bool
}

func NewWorker(db *Database) *Worker {
    return &Worker{
        db:     db,
        logger: log.New(os.Stdout, "[WORKER] ", log.LstdFlags),
        stop:   make(chan bool),
    }
}

func (w *Worker) Start() {
    w.logger.Println("Worker started")
    
    ticker := time.NewTicker(5 * time.Second)
    go func() {
        for {
            select {
            case <-ticker.C:
                w.processTasks()
            case <-w.stop:
                ticker.Stop()
                return
            }
        }
    }()
}

func (w *Worker) Stop() {
    w.stop <- true
    w.logger.Println("Worker stopped")
}

func (w *Worker) processTasks() {
    var tasks []Task
    w.db.DB.Where("status = ? AND (scheduled_for IS NULL OR scheduled_for <= ?)", 
        "pending", time.Now()).
        Order("priority desc, created_at").
        Limit(10).
        Find(&tasks)
    
    for _, task := range tasks {
        w.processTask(&task)
    }
}

func (w *Worker) processTask(task *Task) {
    w.logger.Printf("Processing task %d: %s", task.ID, task.Type)
    
    now := time.Now()
    task.StartedAt = &now
    task.Status = "processing"
    w.db.DB.Save(task)
    
    var err error
    
    switch task.Type {
    case "voice.process":
        err = w.processVoiceTask(task)
    case "ocr.process":
        err = w.processOCRTask(task)
    case "reminder.create":
        err = w.processReminderTask(task)
    case "mis.sync":
        err = w.processMISSyncTask(task)
    default:
        err = fmt.Errorf("unknown task type: %s", task.Type)
    }
    
    if err != nil {
        task.RetryCount++
        if task.RetryCount >= task.MaxRetries {
            task.Status = "failed"
            task.Error = err.Error()
        } else {
            task.Status = "pending"
            // Откладываем повторную попытку
            retryTime := time.Now().Add(time.Duration(task.RetryCount*10) * time.Second)
            task.ScheduledFor = &retryTime
        }
        w.db.DB.Save(task)
        w.logger.Printf("Task %d failed: %v", task.ID, err)
    } else {
        task.Status = "done"
        now := time.Now()
        task.CompletedAt = &now
        w.db.DB.Save(task)
        w.logger.Printf("Task %d completed", task.ID)
    }
}

func (w *Worker) processVoiceTask(task *Task) error {
