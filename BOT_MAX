type Middleware struct {
    auth   *AuthService
    db     *Database
    logger *log.Logger
}

func NewMiddleware(auth *AuthService, db *Database) *Middleware {
    return &Middleware{
        auth:   auth,
        db:     db,
        logger: log.New(os.Stdout, "[MIDDLEWARE] ", log.LstdFlags),
    }
}

// AuthRequired - проверка JWT токена
func (m *Middleware) AuthRequired() gin.HandlerFunc {
    return func(c *gin.Context) {
        authHeader := c.GetHeader("Authorization")
        if authHeader == "" {
            c.JSON(http.StatusUnauthorized, Response{Error: "authorization header required"})
            c.Abort()
            return
        }
        
        parts := strings.Split(authHeader, " ")
        if len(parts) != 2 || parts[0] != "Bearer" {
            c.JSON(http.StatusUnauthorized, Response{Error: "invalid authorization header"})
            c.Abort()
            return
        }
        
        claims, err := m.auth.ValidateToken(parts[1])
        if err != nil {
            c.JSON(http.StatusUnauthorized, Response{Error: "invalid token"})
            c.Abort()
            return
        }
        
        c.Set("user_id", claims.UserID)
        c.Set("user_role", claims.UserRole)
        c.Set("clinic_id", claims.ClinicID)
        
        c.Next()
    }
}

// RoleRequired - проверка роли
func (m *Middleware) RoleRequired(roles ...string) gin.HandlerFunc {
    return func(c *gin.Context) {
        userRole := c.GetString("user_role")
        
        for _, role := range roles {
            if userRole == role {
                c.Next()
                return
            }
        }
        
        c.JSON(http.StatusForbidden, Response{
            Error: fmt.Sprintf("access denied. required roles: %v", roles),
        })
        c.Abort()
    }
}

// SubscriptionRequired - проверка подписки
func (m *Middleware) SubscriptionRequired() gin.HandlerFunc {
    return func(c *gin.Context) {
        userID := c.GetString("user_id")
        userRole := c.GetString("user_role")
        
        // Админы пропускаются
        if userRole == RoleAdmin {
            c.Next()
            return
        }
        
        // Проверяем подписку из Redis
        ctx := context.Background()
        subKey := fmt.Sprintf("subscription:%s", userID)
        
        var subscription UserSubscription
        if err := m.db.Redis.Get(ctx, subKey).Scan(&subscription); err != nil {
            // Если нет в кэше, ищем в БД
            if err := m.db.DB.Where("user_id = ? AND status = ?", userID, SubActive).
                Preload("Tier").First(&subscription).Error; err != nil {
                
                // Для пациентов создаем бесплатную подписку
                if userRole == RolePatient {
                    var freeTier SubscriptionTier
                    if err := m.db.DB.Where("target_role = ? AND name = ?", RolePatient, "Free").First(&freeTier).Error; err == nil {
                        // Создаем бесплатную подписку
                        subscription = UserSubscription{
                            UserID:   uuid.MustParse(userID),
                            UserRole: userRole,
                            TierID:   freeTier.ID,
                            Status:   SubActive,
                            StartDate: time.Now(),
                        }
                        m.db.DB.Create(&subscription)
                        
                        // Кэшируем
                        m.db.Redis.Set(ctx, subKey, subscription, 30*time.Minute)
                        c.Set("subscription", &subscription)
                        c.Next()
                        return
                    }
                }
                
                c.JSON(http.StatusPaymentRequired, Response{
                    Error: "active subscription required",
                    Data: gin.H{"upgrade_url": "/api/subscription/plans"},
                })
                c.Abort()
                return
            }
            
            // Кэшируем
            m.db.Redis.Set(ctx, subKey, subscription, 30*time.Minute)
        }
        
        // Проверяем срок действия
        if subscription.EndDate != nil && subscription.EndDate.Before(time.Now()) {
            c.JSON(http.StatusPaymentRequired, Response{
                Error: "subscription expired",
                Data: gin.H{"upgrade_url": "/api/subscription/renew"},
            })
            c.Abort()
            return
        }
        
        c.Set("subscription", &subscription)
        c.Next()
    }
}

// CheckPatientLimit - проверка лимита пациентов
func (m *Middleware) CheckPatientLimit() gin.HandlerFunc {
    return func(c *gin.Context) {
        userID := c.GetString("user_id")
        userRole := c.GetString("user_role")
        
        if userRole != RoleDoctor && userRole != RoleClinic {
            c.Next()
            return
        }
        
        subVal, exists := c.Get("subscription")
        if !exists {
            c.Next()
            return
        }
        subscription := subVal.(*UserSubscription)
        
        var currentCount int64
        if userRole == RoleDoctor {
            m.db.DB.Model(&Patient{}).Where("user_id IN (SELECT id FROM users WHERE role = ? AND id IN (SELECT user_id FROM doctor_patients WHERE doctor_id = ?))", 
                RolePatient, userID).Count(&currentCount)
        } else {
            m.db.DB.Model(&Patient{}).Where("clinic_id = ?", c.GetString("clinic_id")).Count(&currentCount)
        }
        
        if currentCount >= int64(subscription.Tier.MaxPatients) {
            c.JSON(http.StatusPaymentRequired, Response{
                Error: "patient limit reached",
                Data: gin.H{
                    "current": currentCount,
                    "limit":   subscription.Tier.MaxPatients,
                    "upgrade_url": "/api/subscription/upgrade",
                },
            })
            c.Abort()
            return
        }
        
        c.Set("current_patients", currentCount)
        c.Next()
    }
}

// PatientAccess - проверка доступа к пациенту
func (m *Middleware) PatientAccess() gin.HandlerFunc {
    return func(c *gin.Context) {
        patientID := c.Param("patient_id")
        userID := c.GetString("user_id")
        userRole := c.GetString("user_role")
        
        if patientID == "" {
            c.Next()
            return
        }
        
        pid, err := uuid.Parse(patientID)
        if err != nil {
            c.JSON(http.StatusBadRequest, Response{Error: "invalid patient id"})
            c.Abort()
            return
        }
        
        switch userRole {
        case RolePatient:
            // Пациент видит только себя
            if patientID != userID {
                c.JSON(http.StatusForbidden, Response{Error: "access denied to other patient data"})
                c.Abort()
                return
            }
            
        case RoleDoctor:
            // Врач видит только своих пациентов
            var count int64
            m.db.DB.Model(&DoctorPatientLink{}).
                Where("doctor_id = ? AND patient_id = ?", userID, pid).
                Count(&count)
            
            if count == 0 {
                c.JSON(http.StatusForbidden, Response{Error: "not your patient"})
                c.Abort()
                return
            }
            
        case RoleClinic:
            // Клиника видит пациентов своей клиники
            var count int64
            m.db.DB.Model(&Patient{}).
                Joins("JOIN doctors ON doctors.id = patients.doctor_id").
                Where("doctors.clinic_id = ? AND patients.id = ?", c.GetString("clinic_id"), pid).
                Count(&count)
            
            if count == 0 {
                c.JSON(http.StatusForbidden, Response{Error: "patient not in your clinic"})
                c.Abort()
                return
            }
        }
        
        c.Next()
    }
}

// AuditLog - логирование доступа
func (m *Middleware) AuditLog() gin.HandlerFunc {
    return func(c *gin.Context) {
        start := time.Now()
        
        c.Next()
        
        // Логируем после обработки
        duration := time.Since(start)
        
        // Не логируем статику и healthcheck
        if strings.HasPrefix(c.Request.URL.Path, "/static") || 
           c.Request.URL.Path == "/health" {
            return
        }
        
        // Собираем данные для лога
        userID, _ := uuid.Parse(c.GetString("user_id"))
        patientID, _ := uuid.Parse(c.Param("patient_id"))
        
        log := AccessLog{
            UserID:       userID,
            UserRole:     c.GetString("user_role"),
            Action:       fmt.Sprintf("%s %s", c.Request.Method, c.Request.URL.Path),
            Resource:     c.Request.URL.Path,
            ResourceID:   c.Param("id"),
            PatientID:    &patientID,
            Timestamp:    time.Now(),
            IPAddress:    c.ClientIP(),
            UserAgent:    c.Request.UserAgent(),
            StatusCode:   c.Writer.Status(),
            ResponseTimeMs: int(duration.Milliseconds()),
        }
        
        // Асинхронно сохраняем
        go func() {
            m.db.DB.Create(&log)
        }()
    }
}

