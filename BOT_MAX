// ---------- 13.1 Аутентификация ----------
func (h *APIHandler) Register(c *gin.Context) {
    var req struct {
        Email     string `json:"email" binding:"required,email"`
        Phone     string `json:"phone" binding:"required"`
        Password  string `json:"password" binding:"required,min=6"`
        FirstName string `json:"first_name" binding:"required"`
        LastName  string `json:"last_name" binding:"required"`
        Role      string `json:"role" binding:"required,oneof=patient doctor clinic"`
    }
    
    if err := c.ShouldBindJSON(&req); err != nil {
        c.JSON(http.StatusBadRequest, Response{Error: err.Error()})
        return
    }
    
    // Хешируем пароль
    hash, err := bcrypt.GenerateFromPassword([]byte(req.Password), bcrypt.DefaultCost)
    if err != nil {
        c.JSON(http.StatusInternalServerError, Response{Error: "failed to hash password"})
        return
    }
    
    // Создаем пользователя
    user := User{
        Email:        req.Email,
        Phone:        req.Phone,
        PasswordHash: string(hash),
        FirstName:    req.FirstName,
        LastName:     req.LastName,
        Role:         req.Role,
    }
    
    if err := h.db.DB.Create(&user).Error; err != nil {
        if strings.Contains(err.Error(), "duplicate key") {
            c.JSON(http.StatusConflict, Response{Error: "user already exists"})
            return
        }
        c.JSON(http.StatusInternalServerError, Response{Error: err.Error()})
        return
    }
    
    // Создаем профиль в зависимости от роли
    switch req.Role {
    case RolePatient:
        patient := Patient{UserID: user.ID}
        h.db.DB.Create(&patient)
        
        // Бесплатная подписка
        var freeTier SubscriptionTier
        h.db.DB.Where("target_role = ? AND name = ?", RolePatient, "Free").First(&freeTier)
        if freeTier.ID != uuid.Nil {
            sub := UserSubscription{
                UserID:    user.ID,
                UserRole:  RolePatient,
                TierID:    freeTier.ID,
                Status:    SubActive,
                StartDate: time.Now(),
            }
            h.db.DB.Create(&sub)
        }
        
    case RoleDoctor:
        doctor := Doctor{UserID: user.ID}
        h.db.DB.Create(&doctor)
        
    case RoleClinic:
        clinic := Clinic{Name: req.LastName} // временно
        h.db.DB.Create(&clinic)
    }
    
    // Генерируем токен
    token, err := h.auth.GenerateToken(&user, nil)
    if err != nil {
        c.JSON(http.StatusInternalServerError, Response{Error: "failed to generate token"})
        return
    }
    
    c.JSON(http.StatusCreated, Response{
        Success: true,
        Data: gin.H{
            "user":  user,
            "token": token,
        },
    })
}

func (h *APIHandler) Login(c *gin.Context) {
    var req struct {
        Email    string `json:"email" binding:"required,email"`
        Password string `json:"password" binding:"required"`
    }
    
    if err := c.ShouldBindJSON(&req); err != nil {
        c.JSON(http.StatusBadRequest, Response{Error: err.Error()})
        return
    }
    
    var user User
    if err := h.db.DB.Where("email = ?", req.Email).First(&user).Error; err != nil {
        c.JSON(http.StatusUnauthorized, Response{Error: "invalid credentials"})
        return
    }
    
    if err := bcrypt.CompareHashAndPassword([]byte(user.PasswordHash), []byte(req.Password)); err != nil {
        c.JSON(http.StatusUnauthorized, Response{Error: "invalid credentials"})
        return
    }
    
    // Обновляем время последнего входа
    now := time.Now()
    h.db.DB.Model(&user).Update("last_login_at", now)
    
    // Получаем clinic_id для врача
    var clinicID *uuid.UUID
    if user.Role == RoleDoctor {
        var doctor Doctor
        h.db.DB.Where("user_id = ?", user.ID).First(&doctor)
        clinicID = doctor.ClinicID
    }
    
    token, err := h.auth.GenerateToken(&user, clinicID)
    if err != nil {
        c.JSON(http.StatusInternalServerError, Response{Error: "failed to generate token"})
        return
    }
    
    c.JSON(http.StatusOK, Response{
        Success: true,
        Data: gin.H{
            "user":  user,
            "token": token,
        },
    })
}

