type Database struct {
    DB          *gorm.DB
    SQLDB       *sql.DB
    Redis       *redis.Client
    RabbitMQ    *amqp.Connection
    Encryption  *Encryption
}

func NewDatabase(cfg *Config) (*Database, error) {
    // PostgreSQL
    dsn := fmt.Sprintf("host=%s port=%s user=%s password=%s dbname=%s sslmode=disable TimeZone=UTC",
        cfg.DBHost, cfg.DBPort, cfg.DBUser, cfg.DBPassword, cfg.DBName)
    
    gormDB, err := gorm.Open(postgres.Open(dsn), &gorm.Config{
        Logger: logger.Default.LogMode(logger.Info),
        NowFunc: func() time.Time {
            return time.Now().UTC()
        },
    })
    if err != nil {
        return nil, fmt.Errorf("failed to connect to postgres: %w", err)
    }
    
    sqlDB, err := gormDB.DB()
    if err != nil {
        return nil, fmt.Errorf("failed to get sql db: %w", err)
    }
    
    sqlDB.SetMaxIdleConns(10)
    sqlDB.SetMaxOpenConns(100)
    sqlDB.SetConnMaxLifetime(time.Hour)
    
    // Redis
    redisClient := redis.NewClient(&redis.Options{
        Addr:     fmt.Sprintf("%s:%s", cfg.RedisHost, cfg.RedisPort),
        Password: cfg.RedisPassword,
        DB:       0,
    })
    
    ctx, cancel := context.WithTimeout(context.Background(), 5*time.Second)
    defer cancel()
    
    if err := redisClient.Ping(ctx).Err(); err != nil {
        return nil, fmt.Errorf("failed to connect to redis: %w", err)
    }
    
    // RabbitMQ
    rabbitConn, err := amqp.Dial(cfg.RabbitMQURL)
    if err != nil {
        return nil, fmt.Errorf("failed to connect to rabbitmq: %w", err)
    }
    
    // Encryption
    encryption, err := NewEncryption(cfg.EncryptionKey)
    if err != nil {
        return nil, fmt.Errorf("failed to init encryption: %w", err)
    }
    
    return &Database{
        DB:         gormDB,
        SQLDB:      sqlDB,
        Redis:      redisClient,
        RabbitMQ:   rabbitConn,
        Encryption: encryption,
    }, nil
}

func (db *Database) AutoMigrate() error {
    models := []interface{}{
        &User{}, &Patient{}, &Doctor{}, &Clinic{},
        &SubscriptionTier{}, &UserSubscription{},
        &MedicalRecord{},
        &DocumentTemplate{}, &GeneratedDocument{},
        &Prescription{},
        &LabResult{},
        &SafetyAlert{},
        &MedicalPrompt{},
        &MISConnection{}, &SyncLog{},
        &AccessLog{},
        &Task{},
        &VoiceRecording{},
    }
    
    for _, model := range models {
        if err := db.DB.AutoMigrate(model); err != nil {
            return fmt.Errorf("failed to migrate %T: %w", model, err)
        }
    }
    
    // Индексы
    db.DB.Exec("CREATE INDEX IF NOT EXISTS idx_access_logs_timestamp ON access_logs(timestamp)")
    db.DB.Exec("CREATE INDEX IF NOT EXISTS idx_access_logs_patient_id ON access_logs(patient_id)")
    db.DB.Exec("CREATE INDEX IF NOT EXISTS idx_tasks_status ON tasks(status)")
    db.DB.Exec("CREATE INDEX IF NOT EXISTS idx_tasks_scheduled_for ON tasks(scheduled_for)")
    db.DB.Exec("CREATE INDEX IF NOT EXISTS idx_medical_records_patient_date ON medical_records(patient_id, visit_date)")
    
    return nil
}

func (db *Database) Close() error {
    db.Redis.Close()
    db.RabbitMQ.Close()
    return db.SQLDB.Close()
}

