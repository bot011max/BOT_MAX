// Фабрика адаптеров
type AdapterFactory struct {
    adapters map[string]func() MISAdapter
    mu       sync.RWMutex
}

func NewAdapterFactory() *AdapterFactory {
    f := &AdapterFactory{
        adapters: make(map[string]func() MISAdapter),
    }
    
    // Регистрируем встроенные адаптеры
    f.RegisterAdapter("medods", func() MISAdapter { return &MedodsAdapter{} })
    
    return f
}

func (f *AdapterFactory) RegisterAdapter(misType string, factory func() MISAdapter) {
    f.mu.Lock()
    defer f.mu.Unlock()
    f.adapters[misType] = factory
}

func (f *AdapterFactory) CreateAdapter(misType string, config map[string]interface{}) (MISAdapter, error) {
    f.mu.RLock()
    factory, exists := f.adapters[misType]
    f.mu.RUnlock()
    
    if !exists {
        return nil, fmt.Errorf("unsupported MIS type: %s", misType)
    }
    
    adapter := factory()
    if err := adapter.Initialize(config); err != nil {
        return nil, fmt.Errorf("failed to initialize adapter: %w", err)
    }
    
    return adapter, nil
}

// Менеджер подключений к МИС
type MISConnectionManager struct {
    db        *Database
    factory   *AdapterFactory
    encryptor *Encryption
    mu        sync.RWMutex
    adapters  map[string]MISAdapter
}

func NewMISConnectionManager(db *Database, factory *AdapterFactory, encryptor *Encryption) *MISConnectionManager {
    return &MISConnectionManager{
        db:        db,
        factory:   factory,
        encryptor: encryptor,
        adapters:  make(map[string]MISAdapter),
    }
}

func (m *MISConnectionManager) GetConnection(clinicID uuid.UUID) (MISAdapter, error) {
    m.mu.RLock()
    adapter, exists := m.adapters[clinicID.String()]
    m.mu.RUnlock()
    
    if exists {
        return adapter, nil
    }
    
    // Загружаем из БД
    var conn MISConnection
    if err := m.db.DB.Where("clinic_id = ? AND is_active = ?", clinicID, true).First(&conn).Error; err != nil {
        return nil, err
    }
    
    // Расшифровываем конфиг
    configData, err := m.encryptor.Decrypt(conn.ConfigEncrypted)
    if err != nil {
        return nil, err
    }
    
    var config map[string]interface{}
    if err := json.Unmarshal(configData, &config); err != nil {
        return nil, err
    }
    
    adapter, err := m.factory.CreateAdapter(conn.MisType, config)
    if err != nil {
        return nil, err
    }
    
    m.mu.Lock()
    m.adapters[clinicID.String()] = adapter
    m.mu.Unlock()
    
    return adapter, nil
}

func (m *MISConnectionManager) SaveConnection(clinicID uuid.UUID, misType string, config map[string]interface{}) error {
    configData, err := json.Marshal(config)
    if err != nil {
        return err
    }
    
    encrypted, err := m.encryptor.Encrypt(configData)
    if err != nil {
        return err
    }
    
    conn := MISConnection{
        ClinicID:        clinicID,
        MisType:         misType,
        ConfigEncrypted: encrypted,
        IsActive:        true,
    }
    
    return m.db.DB.Save(&conn).Error
}

