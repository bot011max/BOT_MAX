# База данных
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=medical_bot

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=your-secret-key-here-32-bytes-long!!
JWT_EXPIRY_HOURS=24

# Платежи YooKassa
YOOKASSA_SHOP_ID=your-shop-id
YOOKASSA_SECRET=your-secret-key

# РЛС (справочник лекарств)
AURORA_API_KEY=your-api-key

# Микросервисы
VOICE_SERVICE_URL=http://voice-service:8000
OCR_SERVICE_URL=http://ocr-service:8000
LLM_SERVICE_URL=http://llm-service:8000

# MinIO (S3 для файлов)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=medical-bot

# Ключ шифрования (должен быть 32 байта в base64)
ENCRYPTION_KEY=your-encryption-key-base64-here
